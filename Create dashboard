<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI ContentPilot - Create</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #0B0E14; 
            color: white; 
            overflow-x: hidden;
        }
        .mesh-gradient {
            background: radial-gradient(circle at 50% 0%, #2e1065 0%, #0b0e14 70%);
        }
        .suggestion-pill {
            background: rgba(124, 58, 237, 0.05);
            border: 1px solid rgba(124, 58, 237, 0.1);
            transition: all 0.2s;
        }
        .suggestion-pill:hover {
            background: rgba(124, 58, 237, 0.15);
            border-color: #7c3aed;
            color: white;
        }
        .platform-btn {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.2s;
            color: #6B7280;
            white-space: nowrap;
        }
        .platform-btn.active {
            border-color: #7c3aed;
            background: rgba(124, 58, 237, 0.1);
            color: white;
        }
        textarea::placeholder {
            color: #4B5563;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0B0E14; }
        ::-webkit-scrollbar-thumb { background: #1F2937; border-radius: 10px; }

        /* Loading Animation */
        .loading-spinner {
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top: 2px solid #fff;
            width: 16px;
            height: 16px;
            animation: spin 1s linear infinite;
            display: none;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Mobile Bottom Nav Styles */
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6B7280;
            transition: all 0.2s;
        }
        .mobile-nav-active {
            color: #7c3aed;
        }
    </style>
</head>
<body class="mesh-gradient min-h-screen pb-24 md:pb-0">

    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 border-r border-gray-800/50 flex flex-col p-6 hidden md:flex bg-[#0B0E14]">
            <div class="flex items-center gap-3 mb-10 px-2">
                <div class="w-8 h-8 bg-violet-600 rounded-lg flex items-center justify-center shadow-lg shadow-violet-900/40">
                    <i data-lucide="zap" class="text-white w-5 h-5 fill-current"></i>
                </div>
                <span class="font-bold text-sm tracking-tight uppercase">AI ContentPilot</span>
            </div>
            <nav class="space-y-1">
                <a href="dashboard.html" class="flex items-center gap-3 p-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-wider hover:bg-white/5 transition-all">
                    <i data-lucide="home" class="w-4 h-4"></i> Feed
                </a>
                <a href="create.html" class="flex items-center gap-3 p-3 rounded-xl text-xs font-bold text-white uppercase tracking-wider transition-all" style="background: rgba(124, 58, 237, 0.2); border-right: 3px solid #7c3aed;">
                    <i data-lucide="plus-square" class="w-4 h-4"></i> Create
                </a>
                <a href="scheduler.html" class="flex items-center gap-3 p-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-wider hover:bg-white/5 transition-all">
                    <i data-lucide="calendar" class="w-4 h-4"></i> Scheduler
                </a>
                <a href="analytics.html" class="flex items-center gap-3 p-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-wider hover:bg-white/5 transition-all">
                    <i data-lucide="bar-chart-2" class="w-4 h-4"></i> Analytics
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-6 md:p-12 overflow-y-auto">
            <div class="max-w-4xl mx-auto">
                
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
                    What are we <span class="text-violet-400">shooting</span> today?
                </h1>
                
                <p class="text-gray-400 text-base md:text-lg mb-10 leading-relaxed max-w-2xl">
                    Type an idea. We'll handle the script, visuals, voice and captions.
                </p>

                <!-- Input Card -->
                <div class="bg-[#151921] rounded-[24px] p-8 mb-6 border border-white/5 shadow-2xl">
                    <textarea 
                        id="prompt-input"
                        class="w-full bg-transparent border-none focus:ring-0 text-lg md:text-xl font-medium resize-none min-h-[140px] text-white"
                        placeholder="e.g. 3 productivity hacks that will save you 10 hours a week"
                        maxlength="500"
                    ></textarea>
                    <div class="flex justify-end mt-4 border-t border-white/5 pt-4">
                        <span class="text-gray-600 text-[10px] font-bold uppercase tracking-widest"><span id="char-count">0</span> / 500</span>
                    </div>
                </div>

                <!-- Suggestions -->
                <div class="flex flex-wrap gap-3 mb-12">
                    <button class="suggestion-pill px-5 py-2.5 rounded-full text-[11px] text-gray-400 font-bold uppercase tracking-wider">How to get six pack in 6 months</button>
                    <button class="suggestion-pill px-5 py-2.5 rounded-full text-[11px] text-gray-400 font-bold uppercase tracking-wider">How to cook chicken biriyani at home</button>
                    <button class="suggestion-pill px-5 py-2.5 rounded-full text-[11px] text-gray-400 font-bold uppercase tracking-wider">Explain me every cricket rule</button>
                    <button class="suggestion-pill px-5 py-2.5 rounded-full text-[11px] text-gray-400 font-bold uppercase tracking-wider">Best places to visit in Punjab</button>
                </div>

                <div class="space-y-8">
                    <!-- Publish Section -->
                    <div>
                        <p class="text-gray-500 text-[10px] font-bold uppercase tracking-[0.3em] mb-6">Publish To</p>
                        <div class="flex flex-row flex-wrap gap-3 items-center">
                            <button class="platform-btn active flex items-center gap-2 px-4 py-3 rounded-xl text-[11px] font-bold uppercase">
                                <img src="insta logo.png" class="w-5 h-5 object-contain">Instagram
                                <i data-lucide="check" class="check-icon w-3 h-3 text-violet-400 ml-1"></i>
                            </button>
                            <button class="platform-btn flex items-center gap-2 px-4 py-3 rounded-xl text-[11px] font-bold uppercase">
                                <img src="you logo.png" class="w-5 h-5 object-contain">YouTube
                                <i data-lucide="check" class="check-icon w-3 h-3 text-violet-400 ml-1 hidden"></i>
                            </button>
                            <button class="platform-btn flex items-center gap-2 px-4 py-3 rounded-xl text-[11px] font-bold uppercase">
                                <img src="face logo.png" class="w-5 h-5 object-contain">Facebook
                                <i data-lucide="check" class="check-icon w-3 h-3 text-violet-400 ml-1 hidden"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Action Section -->
                    <div class="flex flex-col items-center justify-center w-full pt-4 gap-6">
                        <button id="generate-btn" class="w-full md:w-auto bg-[#8B5CF6] hover:bg-[#7C3AED] text-white font-bold py-4 px-20 rounded-2xl flex items-center justify-center gap-3 transition-all active:scale-95 shadow-lg shadow-violet-900/40 uppercase text-xs tracking-[0.2em]">
                            <div id="btn-loader" class="loading-spinner"></div>
                            <i id="btn-icon" data-lucide="zap" class="w-4 h-4 fill-current"></i>
                            <span id="btn-text">Generate</span>
                        </button>

                        <!-- Output Display Area -->
                        <div id="output-area" class="w-full bg-[#151921] rounded-[24px] p-8 border border-white/5 shadow-2xl hidden">
                            <h2 class="text-violet-400 font-bold uppercase text-xs tracking-widest mb-4">Generated Content</h2>
                            <div id="output-image-container" class="mb-6 rounded-xl overflow-hidden border border-white/10 hidden">
                                <img id="output-image" src="" alt="Generated Visual" class="w-full h-auto object-cover">
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <p class="text-gray-500 text-[10px] font-bold uppercase mb-1">Caption</p>
                                    <p id="output-caption" class="text-gray-200 leading-relaxed"></p>
                                </div>
                                <div>
                                    <p class="text-gray-500 text-[10px] font-bold uppercase mb-1">Hashtags</p>
                                    <p id="output-hashtags" class="text-violet-400 font-medium"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Persistent Mobile Bottom Navigation -->
    <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-[#0B0E14]/90 backdrop-blur-xl border-t border-gray-800 flex justify-around items-center py-4 px-2 z-50">
        <a href="dashboard.html" class="mobile-nav-item">
            <i data-lucide="home" class="w-6 h-6 mb-1"></i>
            <span>Feed</span>
        </a>
        <a href="create.html" class="mobile-nav-item mobile-nav-active">
            <i data-lucide="plus-square" class="w-6 h-6 mb-1"></i>
            <span>Create</span>
        </a>
        <a href="scheduler.html" class="mobile-nav-item">
            <i data-lucide="calendar" class="w-6 h-6 mb-1"></i>
            <span>Schedule</span>
        </a>
        <a href="analytics.html" class="mobile-nav-item">
            <i data-lucide="bar-chart-2" class="w-6 h-6 mb-1"></i>
            <span>Data</span>
        </a>
    </nav>

    <script>
        lucide.createIcons();

        const API_KEY = "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";
        
        const textarea = document.getElementById('prompt-input');
        const charCount = document.getElementById('char-count');
        const generateBtn = document.getElementById('generate-btn');
        const btnText = document.getElementById('btn-text');
        const btnIcon = document.getElementById('btn-icon');
        const btnLoader = document.getElementById('btn-loader');
        const outputArea = document.getElementById('output-area');
        const outputImage = document.getElementById('output-image');
        const outputImageContainer = document.getElementById('output-image-container');
        const outputCaption = document.getElementById('output-caption');
        const outputHashtags = document.getElementById('output-hashtags');

        textarea.addEventListener('input', () => {
            charCount.textContent = textarea.value.length;
        });

        document.querySelectorAll('.suggestion-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                textarea.value = pill.innerText;
                charCount.textContent = textarea.value.length;
            });
        });

        const platformBtns = document.querySelectorAll('.platform-btn');
        platformBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                platformBtns.forEach(b => {
                    b.classList.remove('active');
                    b.querySelector('.check-icon').classList.add('hidden');
                });
                btn.classList.add('active');
                btn.querySelector('.check-icon').classList.remove('hidden');
            });
        });

        generateBtn.addEventListener('click', async () => {
            const prompt = textarea.value.trim();
            if (!prompt) {
                alert("Please enter a topic first!");
                return;
            }

            generateBtn.disabled = true;
            btnLoader.style.display = "block";
            btnIcon.style.display = "none";
            btnText.innerText = "Generating...";
            outputArea.classList.add('hidden');

            try {
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: {
                        "Authorization": `Bearer ${API_KEY}`,
                        "Content-Type": "application/json",
                        "HTTP-Referer": window.location.origin || "http://localhost",
                        "X-Title": "AI ContentPilot"
                    },
                    body: JSON.stringify({
                        "model": "google/gemini-2.0-flash-001",
                        "messages": [
                            {
                                "role": "system",
                                "content": "Return ONLY a JSON object: {\"img_prompt\": \"...\", \"caption\": \"...\", \"hashtags\": \"...\"}"
                            },
                            {
                                "role": "user",
                                "content": prompt
                            }
                        ]
                    })
                });

                if (!response.ok) throw new Error("API Connection Failed");

                const data = await response.json();
                const aiText = data.choices[0].message.content;
                const jsonMatch = aiText.match(/\{[\s\S]*\}/);
                if (!jsonMatch) throw new Error("Invalid response format from AI.");
                
                const result = JSON.parse(jsonMatch[0]);
                const imageUrl = `https://pollinations.ai/p/${encodeURIComponent(result.img_prompt || result.image_description)}?width=1080&height=1350&nologo=true&seed=${Math.floor(Math.random()*9999)}`;
                
                outputImage.src = imageUrl;
                outputImageContainer.classList.remove('hidden');
                outputCaption.innerText = result.caption;
                outputHashtags.innerText = result.hashtags;
                outputArea.classList.remove('hidden');
                outputArea.scrollIntoView({ behavior: 'smooth' });

            } catch (error) {
                console.error("Error:", error);
                alert("Error: " + error.message);
            } finally {
                generateBtn.disabled = false;
                btnLoader.style.display = "none";
                btnIcon.style.display = "block";
                btnText.innerText = "Generate";
            }
        });
    </script>
</body>
</html>
